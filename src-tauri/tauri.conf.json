{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimeTracker",
  "version": "0.5.1",
  "identifier": "com.jklein.timetracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Time Tracker",
        "width": 1000,
        "height": 740,
        "minWidth": 720,
        "minHeight": 560,
        "dragDropEnabled": false
      },
      {
        "label": "tray",
        "url": "/tray",
        "title": "TimeTracker Schnellzugriff",
        "width": 300,
        "height": 420,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false,
        "focus": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/joe2824/timetracker/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2ODNGRUJBRkMxRkE2ODYKUldTR3BoLzh1djZETmxyVmRvb3Vyek1Lcks3RWNtMTg4WXJxbTd2LzFZRzBNQWErejAyYUYxMFgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
